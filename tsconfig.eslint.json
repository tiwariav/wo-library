{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "composite": false,
    "moduleResolution": "bundler",
    "rootDir": "."
  },
  "include": [
    "packages/js/src/**/*",
    "packages/postcss-config/**/*.d.ts",
    "packages/react/src/**/*",
    "packages/storybook/.storybook/**/*.ts",
    "packages/ui/src/**/*",
    "packages/web/src/**/*"
  ],
  "exclude": ["node_modules", "dist", "coverage", "tmp"]
}
