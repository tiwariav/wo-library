{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "esnext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    "composite": true,
    "paths": {
      "@wo-library/js": ["../js/src/index.ts"],
      "@wo-library/react": ["./src/index.ts"],
      "@wo-library/ui": ["../ui/src/index.ts"],
      "@wo-library/web": ["../web/src/index.ts"],
      "country-flag-emoji-polyfill": [
        "./node_modules/country-flag-emoji-polyfill/dist/index.d.ts"
      ]
    },
    "plugins": [
      {
        "name": "typescript-plugin-css-modules",
        "options": {
          "classnameTransform": "camelCase"
        }
      }
    ]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
