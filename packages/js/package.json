    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "description": "Pure JavaScript/TypeScript utilities",
  "license": "MIT",
  "keywords": [
    "wo-library",
    "utils",
    "javascript",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tiwariav/wo-library.git",
    "directory": "packages/js"
  },
  "homepage": "https://github.com/tiwariav/wo-library/tree/main/packages/js#readme",
  "bugs": {
    "url": "https://github.com/tiwariav/wo-library/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --config ./jest.config.cjs --coverage"
